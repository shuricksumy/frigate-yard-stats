.env
__pycache__/
.pytest_cache/
postgres-projects/
*.har
.claude/
.DS_Store

# Real per-deployment profile config (chat_path/prompts/defaults) -- same reasoning as .env above,
# never committed. frigate/profiles.yaml.example is the checked-in template/reference instead.
frigate/profiles.yaml

# Real per-deployment Frigate config -- same reasoning as .env/profiles.yaml above, never
# committed (it holds real camera RTSP credentials/MQTT password once filled in or substituted).
# frigate/frigate.conf.example is the checked-in template/reference instead.
frigate/frigate.conf

# Runtime data written by bind-mounted volumes -- keep the directories (via .gitkeep) but never
# their contents: stored clips are semi-sensitive (see CLAUDE.md), and the mosquitto dirs are
# just local broker state.
frigate/video-storage/*
!frigate/video-storage/.gitkeep
frigate/video-storage-alerts/*
!frigate/video-storage-alerts/.gitkeep
frigate/mosquitto/data/*
!frigate/mosquitto/data/.gitkeep
frigate/mosquitto/log/*
!frigate/mosquitto/log/.gitkeep

# Ephemeral output from frigate/ingest-worker/demo/ (the docs/images/web-ui-demo.mp4 generator) --
# its own venv and whatever a given run produces; the scripts/real_photos themselves are checked in
# so the demo can be regenerated without redoing any of that setup.
frigate/ingest-worker/demo/venv/
frigate/ingest-worker/demo/recording/
frigate/ingest-worker/demo/shots/
frigate/ingest-worker/demo/video_storage/
frigate/ingest-worker/demo/video_storage_alerts/
frigate/ingest-worker/demo/*.mp4
