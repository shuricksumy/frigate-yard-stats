# One shared template for both stacks/profiles in docker-compose.yml. Each service only reads
# the variables it references, so it's safe to fill in only the section relevant to whichever
# host you're deploying to and leave the other section as "changeme" -- copy this whole file to
# `.env` on each host either way.

# -------------------------------------------------
# Pipeline (docker-compose.yml, --profile pipeline -- postgres-projects + ingest-worker,
# the n8n/Flowise host)
# -------------------------------------------------

# Port ingest-worker's API listens on (both inside the container and the host-side publish) --
# only needs to change if 8080 is already taken by something else on this host.
INGEST_WORKER_API_PORT=8080

POSTGRES_PROJECTS_PASSWORD=changeme

# Same broker Frigate itself publishes frigate/events to -- not recorded anywhere else in this
# repo (n8n's old MQTT Trigger just referenced a saved credential by name), fill in for real.
MQTT_HOST=changeme
MQTT_PORT=1883
MQTT_USERNAME=changeme
MQTT_PASSWORD=changeme
# Optional camera allow-list (comma-separated Frigate camera names, e.g. "outside,outside2") --
# applies to both the events flow (frigate/events) and the alerts flow (frigate/reviews). A
# camera not on this list never gets a raw_events/visits row at all. Leave blank/unset (default)
# to process every camera Frigate reports.
# CAMERAS=outside,outside2

# Frigate's REST API, reachable cross-host from wherever ingest-worker runs (its LAN-bound port,
# not a Docker service name unless both are on the same Docker network).
FRIGATE_API_BASE=http://192.168.1.10:5000

# Shared secret for ingest-worker's read/query/report API (/events, /sightings, /stats, /reports --
# sent as an X-API-Key header). Not required for /health, /status, /crop/{id}, /retention/run.
API_KEY=changeme

# ingest-worker tuning -- all optional, these are the defaults already baked into
# docker-compose.yml. Uncomment and change only the ones you want to override.
# RECORD_WIDTH=3840
# RECORD_HEIGHT=2160
# MAX_CROP_DIMENSION=1280
# THUMBNAIL_MAX_DIMENSION=240
# CROP_PADDING_PCT=0.2
# Where in the event's start->end span to seek for the crop frame (0.0=start, 0.5=midpoint,
# 1.0=end). Frigate's own alert thumbnail is taken at whatever frame scored highest, which isn't
# a fixed offset and isn't exposed via its API -- no universal value matches it, tune from your
# own footage if 0.5 (the default) consistently looks off for your cameras.
# CROP_FRAME_OFFSET_PCT=0.5
# Skips cropping entirely -- crop_image_base64 becomes the full original camera frame (still
# scaled to MAX_CROP_DIMENSION) instead of a region around the object. This is the one field both
# the web UI and the VLM call use, so it changes what gets displayed AND analyzed. Off by default:
# the crop exists so the model can read small detail (plates, notable features) a full wide frame
# makes illegible -- only turn this on if that trade-off is what you want. Ignored for events when
# FRIGATE_SNAPSHOT_ENABLED=true below.
# CROP_DISABLED=false
# Default true: uses Frigate's own already-rendered event snapshot (its own best-detection-score
# frame) instead of seeking+cropping a frame from the record-stream clip ourselves -- beats our
# fixed CROP_FRAME_OFFSET_PCT guess often enough to be the default, at the cost of Frigate's fixed
# lower detect-stream resolution (800x448 in testing, vs. a typical 3840x2160 record stream) with a
# burned-in bbox/label/timestamp overlay this Frigate version's API gives no way to suppress. Set
# to false to fall back to this project's original seek-based approach if that trade-off doesn't
# work for your footage -- CROP_DISABLED/CROP_FRAME_OFFSET_PCT/CROP_PADDING_PCT above only apply
# when this is false. Events only -- a visit's own composite grid (VISIT_THUMB_CROP_ENABLED) is
# unaffected either way.
# FRIGATE_SNAPSHOT_ENABLED=true
# PARALLEL_LIMIT=2
# STALE_MINUTES=5
# MAX_ATTEMPTS=3
# CROP_INITIAL_WAIT_SECONDS=5
# POLL_INTERVAL_SECONDS=5
# RETENTION_MONTHS=12
# RETENTION_CHECK_INTERVAL_SECONDS=86400

# Video storage (third queue stage, video_status) -- off by default. Clips are downloaded from
# Frigate's own clip.mp4 endpoint, stored under VIDEO_STORAGE_HOST_PATH on the host
# (bind-mounted to /data/video in the container), only the path lives in Postgres.
STORE_VIDEO=false
# Host-side directory for stored clips -- relative paths resolve against docker-compose.yml's
# location (frigate/), so the default below is frigate/video-storage/.
VIDEO_STORAGE_HOST_PATH=./video-storage
# VIDEO_PARALLEL_LIMIT=1
# VIDEO_INITIAL_WAIT_SECONDS=10
# VIDEO_MIN_VALID_BYTES=1000
# VIDEO_MAX_ATTEMPTS=5
# VIDEO_RETRY_WAIT_SECONDS=5
# If set, never claim video for events older than this many hours -- lets a backlog age out
# instead of burning attempts on clips likely already rolled off Frigate's recording buffer.
# VIDEO_MAX_AGE_HOURS=6

# Independent video-storage switch for the alerts/visits flow (frigate/reviews) -- one clip per
# visit's whole start_ts->end_ts span, separate from STORE_VIDEO above (which only covers the
# events flow, one clip per raw_event). Shares all the VIDEO_* tuning above; off by default.
STORE_VIDEO_ALERTS=false
# Host-side directory for stored visit clips -- a genuinely separate location from
# VIDEO_STORAGE_HOST_PATH above (own bind mount), not a subfolder of it, so the two flows' disk
# usage can be measured/managed independently. Default resolves to frigate/video-storage-alerts/.
VIDEO_STORAGE_ALERTS_HOST_PATH=./video-storage-alerts

# Independent visit-level preview -- a composite grid image sampling frames proportionally across
# the visit's own clip (0/25/50/100% of its actual duration), plus a separate animated GIF for
# human preview, instead of trying to seek to one precise "best moment" (Frigate's own thumb_time
# turned out unreliable to seek to -- its clip endpoint pads an unpredictable amount of extra
# footage onto either edge of the requested window, inconsistently). Only known once the review
# closes, so this produces SEPARATE artifacts (visits.crop_image_base64/preview_gif_base64, its own
# poll loop) rather than replacing the events-flow crop; off by default.
VISIT_THUMB_CROP_ENABLED=false
# VISIT_THUMB_CROP_PARALLEL_LIMIT=1
# VISIT_THUMB_CROP_INITIAL_WAIT_SECONDS=5
# VISIT_THUMB_CROP_MAX_ATTEMPTS=3
# VISIT_THUMB_CROP_RETRY_WAIT_SECONDS=5
# Which 4 points of the visit's own clip duration to sample for the preview grid/GIF, as
# percentages (0=clip start, 100=clip end) -- e.g. "5,35,65,90" to stay a bit clear of both edges
# instead of landing exactly on them. Must be exactly 4 comma-separated values.
# VISIT_PREVIEW_FRAME_PERCENTAGES=0,25,50,100

# Telegram notifications -- one of none/image/video/all, not a bool. "image" sends the cropped
# photo only; "video" sends the video clip only (as a reply once stored, no photo/GIF); "all"
# sends both. TELEGRAM_BOT_TOKEN/TELEGRAM_CHAT_ID only need to be real values when either mode is
# something other than "none".
TELEGRAM_EVENTS_MODE=none
TELEGRAM_BOT_TOKEN=changeme
TELEGRAM_CHAT_ID=changeme
# Independent mode for the alerts/visits flow -- "image" sends one summary notification per visit
# (preview GIF/photo if ready yet, text-only otherwise), "video" sends the visit's own stored clip
# as a reply to that summary, "all" sends both. Separate from TELEGRAM_EVENTS_MODE above (the
# per-event photo/video messages) -- lets you A/B which is more useful for your traffic.
TELEGRAM_ALERTS_MODE=none
# Defaults to Telegram's own cloud API. Point at the optional telegram-bot-api Compose service
# below instead (http://telegram-bot-api:8081) for lower latency and a 2000MB upload cap instead
# of the cloud API's 50MB -- worth it once STORE_VIDEO/STORE_VIDEO_ALERTS video clips are large
# enough to hit that cap.
TELEGRAM_API_BASE_URL=https://api.telegram.org

# Object labels your Frigate config actually produces -- drives the web UI's Type filter dropdown
# (GET /object-types), so a label you add here shows up in the UI without a frontend change.
OBJECT_TYPES=car,truck,person,dog

# Internal AI stages (ai_worker.py / alert_ai_worker.py) -- an alternative to
# n8n/metadata-processor.json, not a replacement for it: that workflow still works, just needs to
# stay deactivated in n8n while AI_EVENTS_STAGE_ENABLED is on, since both claim from the same
# ai_status queue. Off by default -- see CLAUDE.md's "Internal AI stage" section before enabling.
# Two independent stages/flags, same "independent switch, shared tuning knobs" split as
# STORE_VIDEO/STORE_VIDEO_ALERTS below:
#   AI_EVENTS_STAGE_ENABLED -- analyzes each event's own single-frame crop with profiles.yaml's
#     event_prompt (per sighting_type), writing to vehicle_sightings/person_sightings.
#   AI_ALERTS_ENABLED -- analyzes a visit's own composite grid (needs VISIT_THUMB_CROP_ENABLED=true
#     to ever have anything ready) with profiles.yaml's alert_prompt, writing to the separate
#     visit_vehicle_sightings/visit_person_sightings tables. Can run alongside or instead of the
#     events stage.
# Object types + prompts/model per type live in frigate/profiles.yaml (repo root, bind-mounted by
# docker-compose.yml -- just edit and restart, no rebuild needed), not env vars.
AI_EVENTS_STAGE_ENABLED=false
AI_ALERTS_ENABLED=false
AI_STAGE_PROFILE_PATH=/app/profiles.yaml
AI_STAGE_PARALLEL_LIMIT=2
AI_STAGE_STALE_MINUTES=5
AI_STAGE_MAX_ATTEMPTS=3
AI_STAGE_MAX_AGE_HOURS=
AI_STAGE_POLL_INTERVAL_SECONDS=5
# llama_slot_proxy's own base URL/token, called directly instead of going through n8n -- only
# required when AI_EVENTS_STAGE_ENABLED=true or AI_ALERTS_ENABLED=true. LLAMA_PROXY_TOKEN is
# optional (blank = no Authorization header sent -- llama_slot_proxy is unauthenticated on the LAN
# today, same as every VLM call n8n makes directly).
LLAMA_PROXY_BASE_URL=
LLAMA_PROXY_TOKEN=
LLAMA_PROXY_EMBED_PATH=/REPLACE_WITH_EMBED_SLOT/v1/embeddings
# Fallback chat-completion timeout (seconds) for a profiles.yaml entry that doesn't set its own
# timeout_seconds -- a local model can genuinely take minutes; the real per-type value belongs in
# profiles.yaml (different prompts/models have different load), this is only the fallback.
AI_STAGE_DEFAULT_TIMEOUT_SECONDS=180
# Separate, shorter default for the embedding call -- a single forward pass, not autoregressive
# generation, so normally much faster regardless of which chat model/prompt was used.
AI_STAGE_EMBED_TIMEOUT_SECONDS=60
# Must match the output size of whatever model is loaded behind LLAMA_PROXY_EMBED_PATH (1024 for
# Qwen3-Embedding-0.6B-GGUF, 768 for nomic-embed-text-v1.5, etc). Sizes the pgvector embedding
# columns on vehicle_sightings/person_sightings. Changing this after sightings already have
# embeddings stored clears them (a different model's vectors are an incomparable vector space
# regardless of dimension) -- re-run POST /embeddings/backfill?confirm=true afterwards.
EMBEDDING_DIMENSIONS=1024

# Optional local MQTT broker (mosquitto) -- its own compose profile, fully opt-in:
#   docker compose --profile pipeline --profile mqtt up -d
# then set MQTT_HOST=mosquitto (Compose service-name DNS) / MQTT_PORT=1883 above instead of an
# external broker's IP, if you want everything running from this one compose file.

# Optional self-hosted Telegram Bot API server -- its own compose profile, fully opt-in:
#   docker compose --profile pipeline --profile telegram-bot-api up -d
# then set TELEGRAM_API_BASE_URL=http://telegram-bot-api:8081 above instead of the default
# api.telegram.org. Get these from https://my.telegram.org (a Telegram account credential, not
# the bot token above -- the Local Bot API server needs it to talk to Telegram's backend directly).
TELEGRAM_API_ID=changeme
TELEGRAM_API_HASH=changeme

# -------------------------------------------------
# Frigate NVR stack (docker-compose.yml, --profile nvr -- the Frigate/camera host)
# -------------------------------------------------

FRIGATE_MQTT_PASSWORD=changeme
FRIGATE_RTSP_PASSWORD=changeme

# LAN IP this Frigate host binds its RTSP/WebRTC ports to (its own machine's IP, not a remote one).
FRIGATE_HOST_IP=192.168.1.10
# Broker Frigate connects OUT to -- often the same host as FRIGATE_HOST_IP, but not required to be.
FRIGATE_MQTT_HOST=192.168.1.10
# Camera IPs referenced by go2rtc streams in frigate.conf.
FRIGATE_CAM1_IP=192.168.1.20
FRIGATE_CAM2_IP=192.168.1.21
